# crypto_research_watchlist environment overrides.
# Copy to .env and fill in. Never commit .env.

# SQLite database. Default keeps it next to the repo.
DATABASE_URL=sqlite:///crypto_research_watchlist.db

# Paper-only in v1. Live broker integration is a future phase.
PAPER_TRADING=1

# Demo mode skips network calls and uses the committed parquet for all data.
DEMO_MODE=1

# Telegram (off by default).
# Setup:
#   1. Message @BotFather on Telegram, /newbot, copy the token.
#   2. Send the bot any message so it can reply.
#   3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to find chat.id.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
