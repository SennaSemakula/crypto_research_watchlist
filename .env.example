# crypto_research_watchlist environment overrides.
# Copy to .env and fill in. Never commit .env.

# SQLite database. Default keeps it next to the repo.
DATABASE_URL=sqlite:///crypto_research_watchlist.db

# Paper-only in v1. Live broker integration is a future phase.
PAPER_TRADING=1

# Demo mode skips network calls and uses the committed parquet for all data.
DEMO_MODE=1

# Telegram (off by default).
# Setup:
#   1. Message @BotFather on Telegram, /newbot, copy the token.
#   2. Send the bot any message so it can reply.
#   3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to find chat.id.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CoinGecko Demo API key (free, 30 calls/min, 10k/month).
# Sign up at coingecko.com, generate a Demo key, paste below.
# Used for BTC dominance, total market cap, ETH/BTC ratio.
COINGECKO_API_KEY=

# CryptoCompare News API key (free; ~100k calls/month).
# Replaces CryptoPanic which discontinued its free Developer tier on
# 2026-04-01. Sign up at min-api.cryptocompare.com.
CRYPTOCOMPARE_API_KEY=

# Etherscan v2 unified API key (free, 5 calls/sec).
# Single key covers Ethereum + 60 other EVM chains via the multichain
# endpoint. Sign up at etherscan.io/myapikey.
ETHERSCAN_API_KEY=

# FRED API key (carry-over from the stock side; optional here).
FRED_API_KEY=
